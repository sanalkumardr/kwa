# Postgres connection (the database where migrations 001/002/003 were applied)
DATABASE_URL=postgres://kwa_app:password@localhost:5432/kwa

# JWT secret used to verify the bearer token from field/staff apps.
# The token's `sub` claim must equal an app_user.id (uuid).
JWT_SECRET=change-me-in-prod

# HTTP port
PORT=3000

# Photo storage. STORAGE_PROVIDER=local (UPLOAD_DIR) or s3 (S3-compatible).
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
# For STORAGE_PROVIDER=s3:
# S3_BUCKET=kwa-uploads
# S3_REGION=ap-south-1
# S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com   # or MinIO endpoint
# S3_FORCE_PATH_STYLE=false                          # true for MinIO
# S3_ACCESS_KEY_ID=...        # omit to use instance role / env credentials
# S3_SECRET_ACCESS_KEY=...

# OTP delivery. SMS_PROVIDER=log (default, logs the code) or http (real gateway).
SMS_PROVIDER=log
# For SMS_PROVIDER=http:
# SMS_GATEWAY_URL=https://sms.example.gov.in/send
# SMS_GATEWAY_API_KEY=your-key
# SMS_MESSAGE_TEMPLATE=Your KWA code is {code}. Valid 5 minutes.
# Echo the code in the request-otp response for local dev (NEVER in prod):
OTP_DEV_ECHO=true

# Daily milestone-alert cron runs as this app_user (admin with authority-wide
# scope). Leave unset to disable the scheduled scan. SMS_PROVIDER also drives
# alert delivery (same gateway as OTP).
# SYSTEM_USER_ID=00000000-0000-0000-0000-000000000000
