# ── Node / NestJS backend ───────────────────────────────────────────
node_modules/
dist/
*.tsbuildinfo
.npm/

# ── Environment & secrets (never commit) ────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Uploaded files (local-disk storage; use S3 in prod) ─────────────
# root-anchored: a bare "uploads/" would also swallow backend/src/uploads/
/uploads/
backend/uploads/
/data/

# ── Flutter / Dart mobile ───────────────────────────────────────────
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/build/
mobile/.pub-cache/
mobile/.pub/
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/android/.gradle/
mobile/android/local.properties
mobile/*.iml
**/*.g.dart

# ── Local validation scratch (embedded Postgres data dir) ───────────
pgdata/
*.log

# ── Editor / OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
